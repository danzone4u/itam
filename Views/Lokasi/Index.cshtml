@model IEnumerable<itam.Models.Lokasi>
@{ ViewData["Title"] = "Ruangan"; }
<div class="card card-outline card-primary">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-door-open"></i> Ruangan</h3></div>
    <div class="card-body">
        <div class="mb-3">
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Tambah Ruangan</a>
        </div>
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr><th width="50">No</th><th>Nama Ruangan</th><th>PIC</th><th>Total Barang</th><th width="150">Aksi</th></tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(no++)</td>
                        <td><strong>@item.NamaLokasi</strong></td>
                        <td>@(item.PenanggungJawab ?? "-")</td>
                        <td><span class="badge bg-success">@(ViewData[$"stok_{item.Id}"] ?? 0) unit</span></td>
                        <td>
                            <a href="@Url.Action("Detail", new { id = item.Id })" class="btn btn-info btn-xs"><i class="fas fa-eye"></i> Detail</a>
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-warning btn-xs"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Yakin hapus?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
