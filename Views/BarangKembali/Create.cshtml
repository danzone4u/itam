@model MyGudang.Models.BarangKembali
@{ ViewData["Title"] = "Tambah Pengembalian Barang"; }
<div class="card card-outline card-success">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-undo-alt"></i> Tambah Pengembalian Barang</h3></div>
    <form asp-action="Create" method="post">@Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Referensi Barang Keluar <small class="text-muted">(opsional)</small></label>
                        <select name="BarangKeluarId" id="barangKeluarSelect" class="form-control select2">
                            <option value="">-- Pilih Barang Keluar --</option>
                            @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.BarangKeluars)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    
                    <div id="snContainer" class="form-group" style="display:none; background:#f4f6f9; padding:10px; border-radius:5px; border:1px solid #ddd;">
                        <label>Pilih Serial Number (S/N) yang Dikembalikan:</label>
                        <div id="snList"></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="BarangId"></label>
                        <select asp-for="BarangId" id="BarangId" asp-items="@ViewBag.Barangs" class="form-control select2">
                            <option value="">-- Pilih Barang --</option>
                        </select>
                        <span asp-validation-for="BarangId" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="Jumlah"></label>
                        <input asp-for="Jumlah" id="Jumlah" class="form-control" value="@(ViewBag.PrefilledJumlah ?? 1)" />
                        <span asp-validation-for="Jumlah" class="text-danger"></span>
                        <small class="text-muted temp-sn-warning" style="display:none;">(Otomatis sesuai S/N)</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="TanggalKembali"></label>
                        <input asp-for="TanggalKembali" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="TanggalKembali" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="Kondisi"></label>
                        <select asp-for="Kondisi" id="Kondisi" class="form-control">
                            <option value="Baik">Baik</option>
                            <option value="Rusak Ringan">Rusak Ringan</option>
                            <option value="Rusak Berat">Rusak Berat</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="TindakLanjut"></label>
                        <select asp-for="TindakLanjut" id="TindakLanjut" class="form-control">
                            <option value="Dikembalikan ke Stok">Dikembalikan ke Stok</option>
                            <option value="Di Disposal">Di Disposal</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="DikembalikanOleh"></label>
                        <input asp-for="DikembalikanOleh" id="DikembalikanOleh" class="form-control" value="@(ViewBag.PrefilledPenerima ?? "")" />
                        <span asp-validation-for="DikembalikanOleh" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Keterangan"></label>
                <textarea asp-for="Keterangan" class="form-control" rows="2" placeholder="Catatan tambahan..."></textarea>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Simpan</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    $('#barangKeluarSelect').on('change', function() {
        var id = $(this).val();
        if (id) {
            $.getJSON('@Url.Action("GetBarangKeluarDetail")' + '?id=' + id, function(data) {
                $('#BarangId').val(data.barangId).trigger('change');
                $('#DikembalikanOleh').val(data.penerima);
                
                        // Show SN checkboxes
                $('#snList').empty();
                if (data.serials && data.serials.length > 0) {
                    var html = '';
                    data.serials.forEach(function(s) {
                        html += '<div class="custom-control custom-checkbox d-flex align-items-center mb-2">' +
                                '<input class="custom-control-input sn-check" type="checkbox" name="serialIds" value="' + s.id + '" id="sn_' + s.id + '">' +
                                '<label for="sn_' + s.id + '" class="custom-control-label mr-3" style="min-width: 150px;">' + s.sn + '</label>' +
                                '<select name="snConditions_' + s.id + '" id="cond_' + s.id + '" class="form-control form-control-sm" style="display:none; width: auto;">' +
                                '<option value="Layak Pakai">Layak Pakai</option>' +
                                '<option value="Rusak / Tidak Layak Pakai">Rusak / Tidak Layak Pakai</option>' +
                                '</select>' +
                                '</div>';
                    });
                    $('#snList').html(html);
                    $('#snContainer').slideDown();
                    
                    // Update jumlah when checkbox changes and toggle select visibility
                    $('.sn-check').on('change', function(){
                        var count = $('.sn-check:checked').length;
                        $('#Jumlah').val(count);
                        var id = $(this).val();
                        if($(this).is(':checked')){
                            $('#cond_' + id).show();
                        } else {
                            $('#cond_' + id).hide();
                        }
                    });
                    
                    // Make input readonly and set to 0 initially if SNs exist
                    $('#Jumlah').prop('readonly', true).val(0);
                    $('.temp-sn-warning').show();
                } else {
                    // Jika barang tidak punya S/N, sembunyikan kotak S/N dan biarkan Input Jumlah manual
                    $('#snContainer').slideUp();
                    $('#Jumlah').prop('readonly', false).val(data.jumlah);
                    $('.temp-sn-warning').hide();
                }
            });
        } else {
            $('#snContainer').slideUp();
            $('#Jumlah').prop('readonly', false).val(1);
            $('.temp-sn-warning').hide();
        }
    });

    $('form').on('submit', function(e) {
        if ($('#snContainer').is(':visible') && $('.sn-check').length > 0) {
            if ($('.sn-check:checked').length === 0) {
                e.preventDefault();
                alert('Silakan pilih minimal 1 Serial Number (S/N) yang dikembalikan!');
            }
        }
    });
</script>
}
