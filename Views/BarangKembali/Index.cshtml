@model IEnumerable<MyGudang.Models.BarangKembali>
@{ ViewData["Title"] = "Barang Kembali"; }
<div class="card card-outline card-success">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-undo-alt"></i> Barang Kembali (Retur)</h3>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <a href="@Url.Action("Create")" class="btn btn-success btn-sm"><i class="fas fa-plus"></i> Tambah Pengembalian</a>
            <button class="btn btn-danger btn-sm d-none" id="btnBulkDelete" data-url="@Url.Action("BulkDelete")"><i class="fas fa-trash"></i> Hapus Terpilih (<span id="bulkCount">0</span>)</button>
        </div>
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr>
                    <th width="40"><input type="checkbox" id="checkAll"></th>
                    <th width="50">No</th>
                    <th>Tanggal</th>
                    <th>Barang</th>
                    <th>Jumlah</th>
                    <th>Kondisi</th>
                    <th>Dikembalikan Oleh</th>
                    <th>Keterangan</th>
                    <th width="150">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><input type="checkbox" class="bulk-check" value="@item.Id"></td>
                        <td>@(no++)</td>
                        <td>@item.TanggalKembali.ToString("dd/MM/yyyy")</td>
                        <td>@item.Barang?.NamaBarang</td>
                        <td>@item.Jumlah</td>
                        <td>
                            @if (item.Kondisi == "Baik")
                            {
                                <span class="badge badge-success"><i class="fas fa-check-circle"></i> @item.Kondisi</span>
                            }
                            else if (item.Kondisi == "Rusak Ringan")
                            {
                                <span class="badge badge-warning"><i class="fas fa-exclamation-circle"></i> @item.Kondisi</span>
                            }
                            else
                            {
                                <span class="badge badge-danger"><i class="fas fa-times-circle"></i> @item.Kondisi</span>
                            }
                        </td>
                        <td>@item.DikembalikanOleh</td>
                        <td>@item.Keterangan</td>
                        <td>
                            <a href="@Url.Action("SuratPengembalian", new { id = item.Id })" class="btn btn-info btn-xs" title="Surat"><i class="fas fa-file-alt"></i></a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Yakin hapus data pengembalian ini?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
