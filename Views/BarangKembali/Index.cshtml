@model IEnumerable<itam.Models.BarangKembali>
@{ ViewData["Title"] = "Barang Kembali"; }
<div class="card card-outline card-success">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-undo-alt"></i> Barang Kembali (Retur)</h3>
    </div>
    <div class="card-body">
        <div class="mb-3">
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminGudang"))
            {
                <a href="@Url.Action("Create")" class="btn btn-success btn-sm"><i class="fas fa-plus"></i> Tambah Pengembalian</a>
                <button class="btn btn-danger btn-sm d-none" id="btnBulkDelete" data-url="@Url.Action("BulkDelete")"><i class="fas fa-trash"></i> Hapus Terpilih (<span id="bulkCount">0</span>)</button>
            }
        </div>
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr>
                    <th width="40" class="text-center"><input type="checkbox" id="checkAll"></th>
                    <th width="50" class="text-center">No</th>
                    <th>No. Transaksi</th>
                    <th>Tgl Kembali <i class="fas fa-sort text-muted ml-1"></i></th>
                    <th>Nama Barang</th>
                    <th>S/N</th>
                    <th>Peminjam/Penerima</th>
                    <th class="text-center">Jml</th>
                    <th>Kondisi</th>
                    <th>Tindak Lanjut</th>
                    <th>Ket</th>
                    <th width="100" class="text-center">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center"><input type="checkbox" class="bulk-check" value="@item.Id"></td>
                        <td class="text-center">@no</td>
                        <td>
                            <strong class="text-primary"><i class="fas fa-undo mr-1"></i> RTN-@item.Id.ToString("D4")</strong><br>
                            <small class="text-muted"><i class="fas fa-clock mr-1"></i> @item.CreatedAt.ToString("HH:mm")</small>
                        </td>
                        <td>@item.TanggalKembali.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="font-weight-bold">@item.Barang?.NamaBarang</span>
                            @if (item.BarangKeluarId.HasValue)
                            {
                                <br><small class="text-info"><i class="fas fa-link mr-1"></i> Ref: OUT-@item.BarangKeluarId.Value.ToString("D4")</small>
                            }
                        </td>
                        <td>
                            @{
                                var snList = item.BarangSerials?.Where(s => s.SerialNumber != "-").Select(s => s.SerialNumber).ToList() ?? new List<string>();
                            }
                            @if (snList.Any())
                            {
                                <small class="text-muted">@string.Join(", ", snList)</small>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@item.DikembalikanOleh</td>
                        <td class="text-center"><span class="badge badge-success px-2 py-1" style="font-size: 0.9em;">+@item.Jumlah</span></td>
                        <td>
                            <span class="badge @(item.Kondisi.Contains("Rusak") ? "badge-danger" : "badge-info")">@item.Kondisi</span>
                        </td>
                        <td>
                            @if(item.TindakLanjut == "Di Disposal")
                            {
                                <span class="badge badge-warning"><i class="fas fa-trash-alt"></i> Di Disposal</span>
                            }
                            else if(item.TindakLanjut == "Diperbaiki")
                            {
                                <span class="badge badge-danger"><i class="fas fa-tools"></i> Sedang Diperbaiki</span>
                            }
                            else if(item.TindakLanjut == "Selesai Diperbaiki")
                            {
                                <span class="badge badge-info"><i class="fas fa-check-circle"></i> Selesai Diperbaiki</span>
                            }
                            else
                            {
                                <span class="badge badge-success"><i class="fas fa-box-open"></i> Ke Stok</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Keterangan))
                            {
                                <span data-toggle="tooltip" title="@item.Keterangan">
                                    @(item.Keterangan.Length > 20 ? item.Keterangan.Substring(0, 20) + "..." : item.Keterangan)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action("SuratPengembalian", new { id = item.Id })" class="btn btn-info btn-xs" title="Surat"><i class="fas fa-file-alt"></i></a>
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminGudang"))
                            {
                                @if (item.TindakLanjut == "Diperbaiki")
                                {
                                    <form asp-action="SelesaiPerbaikan" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Tandai barang ini telah selesai diperbaiki dan masukkan kembali ke stok gudang?')">@Html.AntiForgeryToken()<button class="btn btn-success btn-xs" title="Selesai Diperbaiki"><i class="fas fa-check"></i></button></form>
                                }
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Yakin hapus data pengembalian ini?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-xs" title="Hapus"><i class="fas fa-trash"></i></button></form>
                            }
                        </td>
                    </tr>
                    no++;
                }
            </tbody>
        </table>
    </div>
</div>
