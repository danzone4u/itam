@model itam.Models.BarangKembali
@{ ViewData["Title"] = "Surat Pengembalian Barang"; Layout = "~/Views/Shared/_Layout.cshtml"; var kop = ViewBag.Kop as itam.Models.KopSurat ?? new itam.Models.KopSurat(); }

<div class="no-print mb-3">
    <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Cetak</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

<div class="surat-container">
    <div class="surat-header" style="text-align:left; border-bottom:none !important;">
        <div style="display:flex; align-items:center; justify-content:space-between;">
            <div>
                <h3 style="margin:0; font-weight:bold; font-size:22px;">@kop.NamaPerusahaan</h3>
                @if (!string.IsNullOrEmpty(kop.SubJudul)) { <p style="font-size:14px; color:#666; margin:2px 0 0 0;">@kop.SubJudul</p> }
                @if (!string.IsNullOrEmpty(kop.Alamat)) { <p style="font-size:12px; margin:2px 0 0 0;">@kop.Alamat</p> }
                @{
                    var contacts = new List<string>();
                    if (!string.IsNullOrEmpty(kop.Telepon)) contacts.Add("Telp: " + kop.Telepon);
                    if (!string.IsNullOrEmpty(kop.Email)) contacts.Add("Email: " + kop.Email);
                    if (!string.IsNullOrEmpty(kop.Website)) contacts.Add(kop.Website);
                }
                @if (contacts.Any()) { <p style="font-size:11px; color:#888; margin:2px 0 0 0;">@string.Join(" | ", contacts)</p> }
            </div>
            @if (kop.TampilkanLogo)
            {
                <img src="/images/logo-ppn.png" alt="Logo" style="height:112px;">
            }
        </div>
    </div>
    
    <hr style="border-top:3px solid #333; margin:10px 0;" />
    <h2 style="text-align:center; margin-top:20px; font-weight:bold; margin-bottom:25px;">SURAT PENGEMBALIAN BARANG</h2>

        <table style="width:100%; margin-bottom:20px;">
            <tr><td style="width:180px"><strong>No. Surat Kembali</strong></td><td>: @ViewBag.NoSuratKembali</td></tr>
            <tr><td><strong>Tanggal Kembali</strong></td><td>: @Model.TanggalKembali.ToString("dd MMMM yyyy")</td></tr>
            <tr><td><strong>Dikembalikan Oleh</strong></td><td>: @Model.DikembalikanOleh</td></tr>
            <tr><td><strong>Ref. Barang Keluar</strong></td><td>: @(Model.BarangKeluar?.NoSuratJalan ?? "-")</td></tr>
        </table>

        <p>Dengan ini menyatakan bahwa barang berikut telah dikembalikan:</p>
        <table class="table table-bordered" style="margin-bottom:20px;">
            <thead><tr><th>No</th><th>Nama Barang</th><th>Merk & Type</th><th width="50">Jumlah</th><th>Satuan</th><th>Kondisi</th><th>Keterangan</th></tr></thead>
            <tbody>
                <tr><td class="text-center">1</td><td>@Model.Barang?.NamaBarang</td><td>@Model.Barang?.Merk @Model.Barang?.Type</td><td class="text-center">@Model.Jumlah</td><td>@Model.Barang?.Satuan</td><td>@Model.Kondisi</td><td>@Model.Keterangan</td></tr>
            </tbody>
        </table>

        <p>Barang telah diterima kembali dan diserahkan ke gudang dalam kondisi sebagaimana tercantum di atas.</p>

        <div class="surat-ttd" style="display:flex; justify-content:space-between; margin-top:80px; text-align:center; font-size:14pt;">
            <div style="width:30%;">
                <p>Yang Mengembalikan,</p><br/><br/><br/><br/>
                <p>(@Model.DikembalikanOleh)</p>
            </div>
            <div style="width:30%;">
                <p>Mengetahui,</p><br/><br/><br/><br/>
                <p>(..........................)</p>
            </div>
            <div style="width:30%;">
                <p>Yang Menerima,</p><br/><br/><br/><br/>
                <p>(@(kop.NamaPengirim ?? ".........................."))</p>
            </div>
    </div>
</div>
