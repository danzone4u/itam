@model itam.Models.StokOpname
@{ ViewData["Title"] = "Detail Stock Opname"; }
<a href="@Url.Action("Index")" class="btn btn-secondary btn-sm mb-3"><i class="fas fa-arrow-left"></i> Kembali</a>
<div class="card card-outline card-info">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-clipboard-check"></i> Detail Stock Opname - @Model.TanggalOpname.ToString("dd/MM/yyyy")</h3>
        <div class="card-tools">
            <span class="badge @(Model.Status == "Final" ? "bg-success" : "bg-warning") p-2">@Model.Status</span>
            @if (Model.Status == "Draft")
            {
                <form asp-action="Finalize" asp-route-id="@Model.Id" method="post" style="display:inline" onsubmit="return confirm('Finalisasi opname? Stok akan disesuaikan dengan stok fisik.')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-success btn-sm"><i class="fas fa-check"></i> Finalisasi</button>
                </form>
            }
            <a href="@Url.Action("ExportExcel", new { id = Model.Id })" class="btn btn-success btn-sm"><i class="fas fa-file-excel"></i> Export</a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="thead-light">
                <tr><th>No</th><th>Kode</th><th>Nama Barang</th><th>Merk & Type</th><th>Stok Sistem</th><th>Stok Fisik</th><th>Selisih</th><th>Keterangan</th></tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var d in Model.Details!)
                {
                    <tr class="@(d.Selisih < 0 ? "table-danger" : d.Selisih > 0 ? "table-success" : "")">
                        <td>@(no++)</td><td>@d.Barang?.KodeBarang</td><td>@d.Barang?.NamaBarang</td><td>@d.Barang?.Merk @d.Barang?.Type</td>
                        <td>@d.StokSistem</td><td><strong>@d.StokFisik</strong></td>
                        <td>
                            @if (d.Selisih > 0) { <span class="text-success"><strong>+@d.Selisih</strong></span> }
                            else if (d.Selisih < 0) { <span class="text-danger"><strong>@d.Selisih</strong></span> }
                            else { <span>0</span> }
                        </td>
                        <td>@d.Keterangan</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
