@model IEnumerable<itam.Models.StokOpname>
@{ ViewData["Title"] = "Stock Opname"; }
<div class="card card-outline card-warning">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-clipboard-check"></i> Stock Opname</h3>
        <div class="card-tools"><a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Buat Opname</a></div>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr><th width="50">No</th><th>Tanggal</th><th>Keterangan</th><th>Status</th><th width="200">Aksi</th></tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(no++)</td><td>@item.TanggalOpname.ToString("dd/MM/yyyy")</td><td>@item.Keterangan</td>
                        <td><span class="badge @(item.Status == "Final" ? "bg-success" : "bg-warning")">@item.Status</span></td>
                        <td>
                            <a href="@Url.Action("Detail", new { id = item.Id })" class="btn btn-info btn-xs"><i class="fas fa-eye"></i> Detail</a>
                            <a href="@Url.Action("ExportExcel", new { id = item.Id })" class="btn btn-success btn-xs"><i class="fas fa-file-excel"></i> Excel</a>
                            @if (item.Status == "Draft")
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Yakin hapus?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button></form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
