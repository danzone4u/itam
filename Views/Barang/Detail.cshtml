@model MyGudang.Models.Barang
@{
    ViewData["Title"] = "Detail Histori Barang";
    var historiMasuk = ViewBag.HistoriMasuk as IEnumerable<MyGudang.Models.BarangMasuk> ?? new List<MyGudang.Models.BarangMasuk>();
    var historiKembali = ViewBag.HistoriKembali as IEnumerable<MyGudang.Models.BarangKembali> ?? new List<MyGudang.Models.BarangKembali>();
    var historiKeluar = ViewBag.HistoriKeluar as IEnumerable<MyGudang.Models.BarangKeluar> ?? new List<MyGudang.Models.BarangKeluar>();

    var combinedMasuk = historiMasuk.Select(m => new { Tanggal = m.TanggalMasuk, Jumlah = m.Jumlah, Lokasi = m.Lokasi?.NamaLokasi, Keterangan = m.Keterangan, Jenis = "Baru" })
        .Concat(historiKembali.Select(k => new { Tanggal = k.TanggalKembali, Jumlah = k.Jumlah, Lokasi = "Gudang Utama", Keterangan = k.Keterangan ?? "Pengembalian", Jenis = "Retur" }))
        .OrderByDescending(x => x.Tanggal).ToList();
}

<div class="row">
    <div class="col-md-4">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h3 class="card-title">Informasi Barang</h3>
            </div>
            <div class="card-body box-profile">
                @if (!string.IsNullOrEmpty(Model.Gambar))
                {
                    <div class="text-center mb-3">
                        <img class="profile-user-img img-fluid img-circle" src="@Model.Gambar" alt="Gambar Barang" style="width: 150px; height: 150px; object-fit: cover;">
                    </div>
                }
                <h3 class="profile-username text-center">@Model.NamaBarang</h3>
                <p class="text-muted text-center">Kode: @Model.KodeBarang</p>

                <ul class="list-group list-group-unbordered mb-3">
                    <li class="list-group-item">
                        <b>Kategori</b> <a class="float-right">@(Model.Kategori?.NamaKategori ?? "-")</a>
                    </li>
                    <li class="list-group-item">
                        <b>Supplier</b> <a class="float-right">@(Model.Supplier?.NamaSupplier ?? "-")</a>
                    </li>
                    <li class="list-group-item">
                        <b>Satuan</b> <a class="float-right">@Model.Satuan</a>
                    </li>
                    <li class="list-group-item">
                        <b>Total Stok Saat Ini</b> <a class="float-right badge badge-primary" style="font-size: 16px;">@Model.Stok</a>
                    </li>
                </ul>
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-block"><b>Kembali</b></a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-outline card-primary shadow-sm" style="border-top-color: #28a745;">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-arrow-down text-success"></i> Riwayat Masuk Terbaru</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover m-0">
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <th>Status / Jenis</th>
                            <th>Jumlah</th>
                            <th>Ruangan</th>
                            <th>Keterangan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!combinedMasuk.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted">Belum ada riwayat masuk</td></tr>
                        }
                        else
                        {
                            foreach (var item in combinedMasuk.Take(10))
                            {
                                <tr>
                                    <td>@item.Tanggal.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge @(item.Jenis == "Retur" ? "bg-info" : "bg-primary")">@item.Jenis</span></td>
                                    <td><span class="badge bg-success">+@item.Jumlah</span></td>
                                    <td>@(item.Lokasi ?? "Gudang Utama")</td>
                                    <td>@item.Keterangan</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card card-outline card-danger shadow-sm mt-4">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-arrow-up text-danger"></i> Riwayat Keluar Terbaru</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover m-0">
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <th>Jumlah</th>
                            <th>Ruangan</th>
                            <th>Keterangan / Penerima</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!historiKeluar.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted">Belum ada riwayat keluar</td></tr>
                        }
                        else
                        {
                            foreach (var item in historiKeluar.Take(10))
                            {
                                <tr>
                                    <td>@item.TanggalKeluar.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge bg-danger">-@item.Jumlah</span></td>
                                    <td>@(item.Lokasi?.NamaLokasi ?? "Gudang Utama")</td>
                                    <td>@item.Penerima</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
