@model IEnumerable<MyGudang.Models.Barang>
@{ ViewData["Title"] = "Data Barang"; }
<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-boxes"></i> Data Barang</h3>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <a href="@Url.Action("ExportExcel")" class="btn btn-success btn-sm"><i class="fas fa-file-excel"></i> Export</a>
        </div>
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr><th width="30">No</th><th>Kode</th><th width="250">Nama Barang</th><th>Kategori</th><th>Supplier</th><th>Satuan</th><th>Stok</th><th>Ruangan</th><th>Update Terakhir</th><th width="85">Aksi</th></tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(no++)</td><td>@item.KodeBarang</td><td>@item.NamaBarang</td>
                        <td>@item.Kategori?.NamaKategori</td><td>@item.Supplier?.NamaSupplier</td>
                        <td>@item.Satuan</td>
                        <td>
                            <span class="badge @(item.Stok == 0 ? "badge-stok-habis" : item.Stok <= 5 ? "badge-stok-rendah" : "badge-stok-aman")">@item.Stok</span>
                        </td>
                        <td>
                            @{
                                var lokasiDict = ViewBag.LokasiPerBarang as Dictionary<int, List<string>>;
                                var lokasiList = lokasiDict != null && lokasiDict.ContainsKey(item.Id) ? lokasiDict[item.Id] : null;
                            }
                            @if (lokasiList != null && lokasiList.Any())
                            {
                                @foreach (var lok in lokasiList)
                                {
                                    <span class="badge bg-info mr-1">@lok</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td><small class="text-muted">@item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</small></td>
                        <td>
                            <a href="@Url.Action("Detail", new { id = item.Id })" class="btn btn-info btn-xs" title="Lihat Histori Barang"><i class="fas fa-info-circle"></i></a>
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-warning btn-xs" title="Edit Data Barang"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

