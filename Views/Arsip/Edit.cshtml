@model MyGudang.Models.Arsip
@{ ViewData["Title"] = "Edit Arsip"; }
<div class="card card-outline card-warning">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-edit"></i> Edit Arsip</h3></div>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" /><input type="hidden" asp-for="CreatedAt" /><input type="hidden" asp-for="FilePath" />
        <div class="card-body">
            <div class="row">
                <div class="col-md-6"><div class="form-group"><label asp-for="NamaDokumen"></label><input asp-for="NamaDokumen" class="form-control" /><span asp-validation-for="NamaDokumen" class="text-danger"></span></div></div>
                <div class="col-md-6"><div class="form-group"><label asp-for="JenisDokumen"></label>
                    <select asp-for="JenisDokumen" class="form-control"><option value="">-- Pilih --</option><option>Surat Jalan</option><option>Surat Terima</option><option>Invoice</option><option>Laporan</option><option>Lainnya</option></select>
                </div></div>
            </div>
            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="alert alert-info"><i class="fas fa-file"></i> File saat ini: @Model.FilePath</div>
            }
            <div class="form-group"><label>Ganti File</label><input type="file" name="dokumenFile" class="form-control" /></div>
            <div class="form-group"><label asp-for="Keterangan"></label><textarea asp-for="Keterangan" class="form-control" rows="3"></textarea></div>
        </div>
        <div class="card-footer"><button type="submit" class="btn btn-warning"><i class="fas fa-save"></i> Update</button> <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a></div>
    </form>
</div>
