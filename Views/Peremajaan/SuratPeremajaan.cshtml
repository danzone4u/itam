@model MyGudang.Models.Peremajaan
@{ ViewData["Title"] = "Berita Acara Peremajaan Barang"; Layout = "~/Views/Shared/_Layout.cshtml"; var kop = (MyGudang.Models.KopSurat)ViewBag.Kop; }

<div class="no-print mb-3">
    <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Cetak</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

<div class="surat-container">
    <div class="surat-header" style="text-align:left; border-bottom:none !important;">
        <div style="display:flex; align-items:center; justify-content:space-between;">
            <div>
                <h3 style="margin:0; font-weight:bold; font-size:22px;">@kop.NamaPerusahaan</h3>
                @if (!string.IsNullOrEmpty(kop.SubJudul))
                {
                    <p style="font-size:14px; color:#666; margin:2px 0 0 0;">@kop.SubJudul</p>
                }
                @if (!string.IsNullOrEmpty(kop.Alamat))
                {
                    <p style="font-size:12px; margin:2px 0 0 0;">@kop.Alamat</p>
                }
                @{
                    var contacts = new List<string>();
                    if (!string.IsNullOrEmpty(kop.Telepon)) contacts.Add("Telp: " + kop.Telepon);
                    if (!string.IsNullOrEmpty(kop.Email)) contacts.Add("Email: " + kop.Email);
                    if (!string.IsNullOrEmpty(kop.Website)) contacts.Add(kop.Website);
                }
                @if (contacts.Any())
                {
                    <p style="font-size:11px; color:#888; margin:2px 0 0 0;">@string.Join(" | ", contacts)</p>
                }
            </div>
            @if (kop.TampilkanLogo)
            {
                <img src="/images/logo-ppn.png" alt="Logo" style="height:112px;">
            }
        </div>
    </div>
    
    <hr style="border-top:3px solid #333; margin:10px 0;" />
    <h2 style="text-align:center; margin-top:20px; font-weight:bold; margin-bottom:25px;">BERITA ACARA PEREMAJAAN BARANG</h2>

    <table style="width:100%; margin-bottom:20px;">
        <tr><td width="200"><strong>Tanggal Peremajaan</strong></td><td>: @Model.TanggalPeremajaan.ToString("dd MMMM yyyy")</td></tr>
        <tr><td><strong>Dikembalikan Oleh</strong></td><td>: @Model.DikembalikanOleh</td></tr>
        @if (Model.BarangKeluar != null)
        {
            <tr><td><strong>Ref. Barang Keluar</strong></td><td>: @Model.BarangKeluar.NoSuratJalan (@Model.BarangKeluar.TanggalKeluar.ToString("dd MMMM yyyy"))</td></tr>
        }
    </table>

    <p>Dengan ini menyatakan bahwa barang berikut telah dikembalikan dalam rangka peremajaan:</p>

    <table class="table table-bordered" style="margin-top:10px; margin-bottom:20px;">
        <thead><tr><th>No</th><th>Nama Barang</th><th>Jumlah</th><th>Satuan</th><th>Kondisi</th><th>Tindak Lanjut</th></tr></thead>
        <tbody>
            <tr>
                <td>1</td>
                <td>@Model.Barang?.NamaBarang</td>
                <td>@Model.Jumlah</td>
                <td>@Model.Barang?.Satuan</td>
                <td><strong>@Model.Kondisi</strong></td>
                <td><strong>@Model.TindakLanjut</strong></td>
            </tr>
        </tbody>
    </table>

    @if (!string.IsNullOrEmpty(Model.Keterangan))
    {
        <p><strong>Keterangan:</strong> @Model.Keterangan</p>
    }

    <div class="surat-ttd" style="margin-top:40px;">
        <div>
            <p><strong>Yang Menyerahkan</strong></p>
            <br><br><br><br>
            <p>(@Model.DikembalikanOleh)</p>
        </div>
        <div>
            <p><strong>Mengetahui</strong></p>
            <br><br><br><br>
            <p>(........................................)</p>
        </div>
        <div>
            <p><strong>Yang Menerima</strong></p>
            <br><br><br><br>
            <p>(@(kop.NamaPengirim ?? "........................................"))</p>
            @if (!string.IsNullOrEmpty(kop.JabatanPengirim))
            {
                <p style="font-size:12px; color:#666;">@kop.JabatanPengirim</p>
            }
        </div>
    </div>
</div>
