@model IEnumerable<MyGudang.Models.Peremajaan>
@{ ViewData["Title"] = "Peremajaan Barang"; }
<div class="card card-outline card-purple">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-sync-alt text-purple"></i> Peremajaan Barang</h3>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Tambah</a>
        </div>
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr><th width="30">No</th><th>Tanggal</th><th width="250">Barang</th><th>Jumlah</th><th>S/N</th><th>Dikembalikan Oleh</th><th>Kondisi</th><th>Tindak Lanjut</th><th width="85">Aksi</th></tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    var kondisiBadge = item.Kondisi switch { "Layak Pakai" => "badge-success", "Perlu Perbaikan" => "badge-warning", "Rusak" => "badge-danger", _ => "badge-secondary" };
                    var tindakBadge = item.TindakLanjut switch { "Masuk Inventaris" => "badge-info", "Disposal" => "badge-danger", "Perbaikan" => "badge-warning", _ => "badge-secondary" };
                    <tr>
                        <td>@(no++)</td>
                        <td>@item.TanggalPeremajaan.ToString("dd/MM/yyyy")</td>
                        <td>@item.Barang?.NamaBarang</td>
                        <td>@item.Jumlah</td>
                        <td><small>@(item.BarangSerials != null && item.BarangSerials.Any() ? string.Join(", ", item.BarangSerials.Select(s => s.SerialNumber)) : "-")</small></td>
                        <td>@item.DikembalikanOleh</td>
                        <td><span class="badge @kondisiBadge">@item.Kondisi</span></td>
                        <td><span class="badge @tindakBadge">@item.TindakLanjut</span></td>
                        <td>
                            <a href="@Url.Action("SuratPeremajaan", new { id = item.Id })" class="btn btn-info btn-xs" title="Cetak BA"><i class="fas fa-print"></i> BA</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Yakin hapus data peremajaan ini?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
