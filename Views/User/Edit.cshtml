@model Microsoft.AspNetCore.Identity.IdentityUser
@{ ViewData["Title"] = "Edit User"; }
<div class="card card-outline card-warning">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-user-edit"></i> Edit User: @Model.UserName</h3></div>
    <form asp-action="Edit" method="post">@Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="card-body">
            <div class="row">
                <div class="col-md-4"><div class="form-group"><label>Username</label><input type="text" name="username" class="form-control" value="@Model.UserName" required /></div></div>
                <div class="col-md-4"><div class="form-group"><label>Email</label><input type="email" name="email" class="form-control" value="@Model.Email" /></div></div>
                <div class="col-md-4"><div class="form-group"><label>Role</label><select name="role" class="form-control" required>@foreach (var r in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Roles){if (r.Value == (string)ViewBag.CurrentRole){<option value="@r.Value" selected>@r.Text</option>}else{<option value="@r.Value">@r.Text</option>}}</select></div></div>
            </div>
            <hr/>
            <h5><i class="fas fa-key"></i> Ganti Password <small class="text-muted">(kosongkan jika tidak ingin mengubah)</small></h5>
            <div class="row">
                <div class="col-md-6"><div class="form-group"><label>Password Baru</label><input type="password" name="newPassword" class="form-control" /><small class="text-muted">Minimal 6 karakter</small></div></div>
            </div>
        </div>
        <div class="card-footer"><button type="submit" class="btn btn-warning"><i class="fas fa-save"></i> Update</button> <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a></div>
    </form>
</div>
