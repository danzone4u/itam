@{ ViewData["Title"] = "Tambah User"; }
<div class="card card-outline card-primary">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-user-plus"></i> Tambah User</h3></div>
    <form asp-action="Create" method="post">@Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row">
                <div class="col-md-4"><div class="form-group"><label>Username</label><input type="text" name="username" class="form-control" required /><small class="text-muted">Minimal 3 karakter</small></div></div>
                <div class="col-md-4"><div class="form-group"><label>Email</label><input type="email" name="email" class="form-control" /></div></div>
                <div class="col-md-4"><div class="form-group"><label>Role</label><select name="role" class="form-control" required>@foreach (var r in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Roles){<option value="@r.Value">@r.Text</option>}</select></div></div>
            </div>
            <div class="row">
                <div class="col-md-6"><div class="form-group"><label>Password</label><input type="password" name="password" class="form-control" required /><small class="text-muted">Minimal 6 karakter</small></div></div>
            </div>
        </div>
        <div class="card-footer"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button> <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a></div>
    </form>
</div>
