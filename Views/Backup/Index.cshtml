@{
    ViewData["Title"] = "Backup & Restore";
    var setting = ViewBag.Setting as MyGudang.Models.BackupSetting;
    var files = ViewBag.BackupFiles as List<System.IO.FileInfo> ?? new List<System.IO.FileInfo>();
}

<div class="row">
    <div class="col-md-4">
        <!-- Backup Settings Card -->
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-cog"></i> Pengaturan Backup</h3>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span><i class="fas fa-clock"></i> Auto Backup</span>
                    <form asp-action="ToggleAutoBackup" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(setting?.AutoBackupEnabled == true ? "btn-success" : "btn-secondary")">
                            <i class="fas @(setting?.AutoBackupEnabled == true ? "fa-toggle-on" : "fa-toggle-off")"></i>
                            @(setting?.AutoBackupEnabled == true ? "Aktif" : "Nonaktif")
                        </button>
                    </form>
                </div>

                <form asp-action="UpdateInterval" method="post">
                    @Html.AntiForgeryToken()
                    <div class="input-group mb-3">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-hourglass-half"></i></span>
                        </div>
                        <input type="number" name="hours" class="form-control" value="@setting?.IntervalHours" min="1" max="168" placeholder="Interval jam">
                        <div class="input-group-append">
                            <span class="input-group-text">jam</span>
                            <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-save"></i></button>
                        </div>
                    </div>
                </form>

                <div class="text-muted small mb-3">
                    <i class="fas fa-info-circle"></i> Backup otomatis maksimal menyimpan 10 file terakhir.
                </div>

                @if (setting?.LastBackupAt != null)
                {
                    <div class="callout callout-info p-2">
                        <small><i class="fas fa-history"></i> Backup terakhir:<br>
                        <strong>@setting.LastBackupAt.Value.ToString("dd/MM/yyyy HH:mm:ss")</strong></small>
                    </div>
                }

                <form asp-action="CreateBackup" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-block" onclick="return confirm('Buat backup database sekarang?')">
                        <i class="fas fa-database"></i> Backup Sekarang
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <!-- Backup Files Card -->
        <div class="card card-outline card-success">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-archive"></i> Daftar File Backup (@files.Count)</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover m-0">
                    <thead>
                        <tr>
                            <th>Nama File</th>
                            <th>Ukuran</th>
                            <th>Tanggal</th>
                            <th width="200">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!files.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4"><i class="fas fa-inbox fa-2x mb-2 d-block"></i>Belum ada file backup</td></tr>
                        }
                        else
                        {
                            foreach (var file in files)
                            {
                                var sizeMB = (file.Length / 1024.0 / 1024.0).ToString("F2");
                                var isAuto = file.Name.Contains("_Auto_");
                                <tr>
                                    <td>
                                        <i class="fas fa-file-archive text-warning"></i>
                                        @file.Name
                                        @if (isAuto)
                                        {
                                            <span class="badge badge-info ml-1">Auto</span>
                                        }
                                    </td>
                                    <td>@sizeMB MB</td>
                                    <td><small>@file.CreationTime.ToString("dd/MM/yyyy HH:mm")</small></td>
                                    <td>
                                        <a href="@Url.Action("Download", new { fileName = file.Name })" class="btn btn-success btn-xs" title="Download">
                                            <i class="fas fa-download"></i>
                                        </a>
                                        <form asp-action="Restore" method="post" style="display:inline" onsubmit="return confirm('PERINGATAN! Restore akan menimpa seluruh database saat ini. Pastikan Anda sudah backup data terbaru. Lanjutkan?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="fileName" value="@file.Name">
                                            <button type="submit" class="btn btn-warning btn-xs" title="Restore">
                                                <i class="fas fa-undo"></i> Restore
                                            </button>
                                        </form>
                                        <form asp-action="DeleteBackup" method="post" style="display:inline" onsubmit="return confirm('Hapus file backup ini?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="fileName" value="@file.Name">
                                            <button type="submit" class="btn btn-danger btn-xs" title="Hapus">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
