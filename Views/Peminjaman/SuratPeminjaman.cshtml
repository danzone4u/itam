@model MyGudang.Models.Peminjaman
@{ ViewData["Title"] = "Surat Peminjaman"; Layout = null; }
@{
    var kop = ViewBag.Kop as MyGudang.Models.KopSurat ?? new MyGudang.Models.KopSurat();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Surat Peminjaman - @Model.NoPeminjaman</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/3.2.0/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="/css/site.css">
    <style>
        body { font-family: 'Times New Roman', serif; font-size: 12pt; }
        .surat-container { max-width: 100%; padding: 40px; }
    </style>
</head>
<body>
<div class="container-fluid p-4">
    <div class="surat-container">
        <div class="no-print text-right mb-3">
            <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Cetak</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
        </div>

        @if (kop.TampilkanLogo)
        {
            <table style="width:100%; border-bottom:3px double #333; padding-bottom:15px; margin-bottom:25px;">
                <tr>
                    <td style="vertical-align:middle;">
                        <h3 style="margin:0; font-weight:bold; font-size:18pt;">@kop.NamaPerusahaan</h3>
                        @if (!string.IsNullOrEmpty(kop.SubJudul)) { <p style="margin:2px 0 0 0; font-size:12pt;">@kop.SubJudul</p> }
                        @if (!string.IsNullOrEmpty(kop.Alamat)) { <p style="margin:2px 0 0 0; font-size:10pt; color:#555;">@kop.Alamat</p> }
                    </td>
                    <td style="text-align:right; vertical-align:middle; width:150px;">
                        <img src="/images/logo-ppn.png" alt="Logo" style="height:120px;">
                    </td>
                </tr>
            </table>
        }

        <h4 class="text-center" style="font-weight:bold; margin-bottom:20px;">SURAT PEMINJAMAN BARANG</h4>

        <table style="margin-bottom:20px;">
            <tr><td style="width:180px"><strong>No. Peminjaman</strong></td><td>: @Model.NoPeminjaman</td></tr>
            <tr><td><strong>Tanggal Pinjam</strong></td><td>: @Model.TanggalPinjam.ToString("dd MMMM yyyy")</td></tr>
            <tr><td><strong>Jatuh Tempo</strong></td><td>: @Model.TanggalJatuhTempo.ToString("dd MMMM yyyy")</td></tr>
            <tr><td><strong>Peminjam</strong></td><td>: @Model.Peminjam</td></tr>
            @if (!string.IsNullOrEmpty(Model.NipNik)) { <tr><td><strong>NIP/NIK</strong></td><td>: @Model.NipNik</td></tr> }
            @if (!string.IsNullOrEmpty(Model.Departemen)) { <tr><td><strong>Departemen</strong></td><td>: @Model.Departemen</td></tr> }
            @if (!string.IsNullOrEmpty(Model.NoHp)) { <tr><td><strong>No. HP</strong></td><td>: @Model.NoHp</td></tr> }
        </table>

        <p>Dengan ini menyatakan meminjam barang sebagai berikut:</p>
        <table class="table table-bordered" style="margin-bottom:20px;">
            <thead><tr><th>No</th><th>Nama Barang</th><th>Jumlah</th><th>Satuan</th><th>Keterangan</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>@Model.Barang?.NamaBarang</td><td>@Model.Jumlah</td><td>@Model.Barang?.Satuan</td><td>@Model.Keterangan</td></tr>
            </tbody>
        </table>

        <p>Peminjam bertanggung jawab atas barang yang dipinjam dan wajib mengembalikan dalam kondisi baik sebelum tanggal jatuh tempo.</p>

        @if (Model.Status == "Dikembalikan" && Model.TanggalKembali.HasValue)
        {
            <div style="border:1px solid #28a745; padding:10px; margin:15px 0; border-radius:5px;">
                <strong style="color:#28a745;"><i class="fas fa-check-circle"></i> SUDAH DIKEMBALIKAN</strong><br/>
                Tanggal Kembali: @Model.TanggalKembali.Value.ToString("dd MMMM yyyy") — Kondisi: @Model.KondisiKembali
            </div>
        }

        <div class="surat-ttd" style="display:flex; justify-content:space-between; margin-top:80px; text-align:center; font-size:14pt;">
            <div style="width:30%;">
                <p>Peminjam,</p><br/><br/><br/><br/>
                <p>(@Model.Peminjam)</p>
            </div>
            <div style="width:30%;">
                <p>Mengetahui,</p><br/><br/><br/><br/>
                <p>(..........................)</p>
            </div>
            <div style="width:30%;">
                <p>Penanggung Jawab Gudang,</p><br/><br/><br/><br/>
                <p>(@(kop.NamaPengirim ?? ".........................."))</p>
            </div>
        </div>
    </div>
</div>
</body>
</html>
