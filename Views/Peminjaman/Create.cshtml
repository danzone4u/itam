@model itam.Models.Peminjaman
@{ ViewData["Title"] = "Tambah Peminjaman"; }
<div class="card card-outline card-purple">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-plus"></i> Tambah Peminjaman</h3></div>
    <form asp-action="CreateMultiple" method="post">@Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Tanggal Pinjam</label>
                        <input type="date" name="tanggalPinjam" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Jatuh Tempo</label>
                        <input type="date" name="tanggalJatuhTempo" class="form-control" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")" required />
                        <small class="text-muted">Default: 7 hari</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Peminjam</label>
                        <input type="text" name="peminjam" class="form-control" placeholder="Nama peminjam" required />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>NIP/NIK</label>
                        <input type="text" name="nipNik" class="form-control" placeholder="Opsional" />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Departemen</label>
                        <input type="text" name="departemen" class="form-control" placeholder="Divisi / Unit" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>No. HP</label>
                        <input type="text" name="noHp" class="form-control" placeholder="08xxxxxxxxxx" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Keterangan</label>
                        <input type="text" name="keteranganGlobal" class="form-control" placeholder="Keperluan peminjaman" />
                    </div>
                </div>
            </div>

            <hr/>
            <h5><i class="fas fa-boxes"></i> Daftar Barang</h5>
            <div class="row mb-2">
                <div class="col-md-6">
                    <label>Pilih Barang</label>
                    <input type="text" id="searchBarang" class="form-control" list="listBarang" placeholder="Ketik nama barang..." autocomplete="off" />
                    <datalist id="listBarang">
                        @if (ViewBag.Barangs != null)
                        {
                            foreach (var b in (IEnumerable<itam.Models.Barang>)ViewBag.Barangs)
                            {
                                <option value="@b.NamaBarang (Stok: @b.Stok)" data-id="@b.Id" data-nama="@b.NamaBarang" data-stok="@b.Stok" data-satuan="@b.Satuan"></option>
                            }
                        }
                    </datalist>
                    <input type="hidden" id="selectedBarangId" />
                </div>
                <div class="col-md-3">
                    <label>Jumlah</label>
                    <input type="number" id="inputJumlah" class="form-control" placeholder="Jumlah" min="1" value="1" />
                </div>
                <div class="col-md-3">
                    <label>&nbsp;</label>
                    <button type="button" id="btnAddBarang" class="btn btn-success btn-block"><i class="fas fa-plus"></i> Tambah</button>
                </div>
            </div>

            <table class="table table-bordered mt-3" id="tblBarang">
                <thead class="thead-light">
                    <tr><th width="50">No</th><th>Nama Barang</th><th>Satuan</th><th width="100">Jumlah</th><th width="60">Aksi</th></tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary" id="btnSubmit" disabled><i class="fas fa-save"></i> Simpan Peminjaman</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
$(function(){
    var rowNum = 0;
    $('#btnAddBarang').click(function(){
        var typed = $('#searchBarang').val();
        if (!typed) { Swal.fire('Peringatan', 'Ketik dan pilih barang terlebih dahulu!', 'warning'); return; }

        // Find matching option in datalist
        var matched = null;
        $('#listBarang option').each(function(){
            if ($(this).val() === typed) { matched = $(this); return false; }
        });
        if (!matched) { Swal.fire('Peringatan', 'Barang tidak ditemukan! Pilih dari daftar.', 'warning'); return; }

        var barangId = matched.data('id');
        var nama = matched.data('nama');
        var stok = parseInt(matched.data('stok'));
        var satuan = matched.data('satuan');
        var jumlah = parseInt($('#inputJumlah').val()) || 1;
        if (jumlah > stok) { Swal.fire('Peringatan', 'Jumlah melebihi stok! (Stok: ' + stok + ')', 'warning'); return; }
        if (jumlah < 1) { Swal.fire('Peringatan', 'Jumlah minimal 1!', 'warning'); return; }

        // Check if barang already in table
        var exists = false;
        $('#tblBarang tbody tr').each(function(){
            if ($(this).data('barangid') == barangId) { exists = true; return false; }
        });
        if (exists) { Swal.fire('Peringatan', 'Barang sudah ada di daftar!', 'warning'); return; }

        rowNum++;
        var row = '<tr data-barangid="' + barangId + '">'
            + '<td class="row-num">' + rowNum + '</td>'
            + '<td>' + nama + '<input type="hidden" name="barangIds" value="' + barangId + '"></td>'
            + '<td>' + satuan + '</td>'
            + '<td>' + jumlah + '<input type="hidden" name="jumlahs" value="' + jumlah + '"></td>'
            + '<td><button type="button" class="btn btn-danger btn-xs remove-row"><i class="fas fa-times"></i></button></td>'
            + '</tr>';
        $('#tblBarang tbody').append(row);
        $('#searchBarang').val('');
        $('#inputJumlah').val(1);
        updateSubmit();
    });

    $(document).on('click', '.remove-row', function(){
        $(this).closest('tr').remove();
        // Renumber
        rowNum = 0;
        $('#tblBarang tbody tr').each(function(){ rowNum++; $(this).find('.row-num').text(rowNum); });
        updateSubmit();
    });

    function updateSubmit(){
        var cnt = $('#tblBarang tbody tr').length;
        $('#btnSubmit').prop('disabled', cnt === 0);
    }
});
</script>
}
