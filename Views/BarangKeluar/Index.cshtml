@model IEnumerable<MyGudang.Models.BarangKeluar>
@{ ViewData["Title"] = "Barang Keluar"; }
<div class="card card-outline card-danger">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-arrow-up text-danger"></i> Barang Keluar</h3>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Tambah</a>
            <a href="@Url.Action("ExportExcel")" class="btn btn-success btn-sm"><i class="fas fa-file-excel"></i> Export</a>
            <button class="btn btn-danger btn-sm d-none" id="btnBulkDelete" data-url="@Url.Action("BulkDelete")"><i class="fas fa-trash"></i> Hapus Terpilih (<span id="bulkCount">0</span>)</button>
        </div>
        <table class="table table-bordered table-hover data-table">
            <thead class="thead-light">
                <tr><th width="40"><input type="checkbox" id="checkAll"></th><th width="50">No</th><th>No. Surat Jalan</th><th>Tanggal</th><th>Barang</th><th>Jumlah</th><th>Ruangan</th><th>Penerima</th><th>No HP</th><th width="220">Aksi</th></tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><input type="checkbox" class="bulk-check" value="@item.Id"></td>
                        <td>@(no++)</td><td><span class="badge bg-secondary">@item.NoSuratJalan</span></td><td>@item.TanggalKeluar.ToString("dd/MM/yyyy")</td><td>@item.Barang?.NamaBarang</td>
                        <td><span class="badge bg-danger">-@item.Jumlah</span></td>
                        <td>@(item.Lokasi?.NamaLokasi ?? "-")</td>
                        <td>@item.Penerima</td><td>@item.NoHpPenerima</td>
                        <td>
                            <a href="@Url.Action("SuratJalan", new { id = item.Id })" class="btn btn-info btn-xs" title="Surat Jalan"><i class="fas fa-file-alt"></i> SJ</a>
                            <a href="@Url.Action("SuratTerimaBarang", new { id = item.Id })" class="btn btn-secondary btn-xs" title="Berita Acara Serah Terima"><i class="fas fa-receipt"></i> BAST</a>
                            <a href="@Url.Action("Create", "BarangKembali", new { barangKeluarId = item.Id })" class="btn btn-success btn-xs" title="Kembalikan Barang"><i class="fas fa-undo"></i></a>
                            <a href="@Url.Action("Create", "Peremajaan", new { barangKeluarId = item.Id })" class="btn btn-xs" style="background:#6f42c1;color:#fff;" title="Peremajaan"><i class="fas fa-sync-alt"></i></a>
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-warning btn-xs" title="Edit"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Yakin hapus?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
