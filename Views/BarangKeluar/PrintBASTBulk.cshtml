@model IEnumerable<itam.Models.BarangKeluar>
@{ 
    ViewData["Title"] = "BAST Barang Keluar"; 
    Layout = "~/Views/Shared/_Layout.cshtml"; 
    var kop = (itam.Models.KopSurat)ViewBag.Kop; 
    var groupedData = Model.OrderBy(x => x.TanggalKeluar).GroupBy(x => x.NoSuratJalan).ToList();

    // extract base STB prefix from ViewBag
    string baseBast = ViewBag.NoBast ?? ""; 
    var bastParts = baseBast.Split('/');
    var bastPrefix = bastParts.Length > 0 ? bastParts.First() : "STB";
}

<style>
    @@media print {
        .page-break { page-break-after: always; }
        .page-break:last-child { page-break-after: auto; }
    }
</style>

<div class="no-print mb-3">
    <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Cetak</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

@{ int groupIdx = 0; }
@foreach (var group in groupedData)
{
    // Generate a unique BAST number leveraging the Surat Jalan string but with BAST prefix.
    // E.g SJ/PNDITS/XXX -> STB/PNDITS/XXX
    string currentBast = group.Key ?? "";
    if (!string.IsNullOrEmpty(currentBast) && currentBast.Contains('/')) 
    {
        var parts = currentBast.Split('/');
        parts[0] = bastPrefix; // replace 'SJ' with 'STB'
        currentBast = string.Join("/", parts);
    }
    else 
    {
        currentBast = bastPrefix + "-" + (string.IsNullOrEmpty(currentBast) ? "AUTOGEN" : currentBast);
    }

    <div class="surat-container page-break" style="margin-bottom: 30px;">
        <div class="surat-header" style="text-align:left; border-bottom:none !important;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
                <div>
                    <h3 style="margin:0; font-weight:bold; font-size:22px;">@kop.NamaPerusahaan</h3>
                    @if (!string.IsNullOrEmpty(kop.SubJudul)) { <p style="font-size:14px; color:#666; margin:2px 0 0 0;">@kop.SubJudul</p> }
                    @if (!string.IsNullOrEmpty(kop.Alamat)) { <p style="font-size:12px; margin:2px 0 0 0;">@kop.Alamat</p> }
                    @{
                        var contacts = new List<string>();
                        if (!string.IsNullOrEmpty(kop.Telepon)) contacts.Add("Telp: " + kop.Telepon);
                        if (!string.IsNullOrEmpty(kop.Email)) contacts.Add("Email: " + kop.Email);
                        if (!string.IsNullOrEmpty(kop.Website)) contacts.Add(kop.Website);
                    }
                    @if (contacts.Any()) { <p style="font-size:11px; color:#888; margin:2px 0 0 0;">@string.Join(" | ", contacts)</p> }
                </div>
                @if (kop.TampilkanLogo) { <img src="/images/logo-ppn.png" alt="Logo" style="height:112px;"> }
            </div>
        </div>
        
        <hr style="border-top:3px solid #333; margin:10px 0;" />
        <h2 style="text-align:center; margin-top:20px; font-weight:bold; margin-bottom:25px;">BERITA ACARA SERAH TERIMA<br/>BARANG KELUAR</h2>

        <table style="width:100%; margin-bottom:20px;">
            <tr><td width="150"><strong>No. BAST</strong></td><td>: @currentBast</td></tr>
            <tr><td><strong>Tanggal Serah Terima</strong></td><td>: @group.First().TanggalKeluar.ToString("dd MMMM yyyy")</td></tr>
        </table>

        <p>Kami yang bertanda tangan di bawah ini, menyatakan telah menyerahkan dan menerima barang-barang dengan rincian sebagai berikut:</p>

        <table class="table table-bordered" style="margin-top:10px;">
            <thead>
                <tr>
                    <th width="50">No</th>
                    <th>Nama Barang</th>
                    <th>Nama Barang</th>
                    <th width="50">Jumlah</th>
                    <th>S/N</th>
                    <th>Keterangan</th>
                </tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in group)
                {
                    <tr>
                        <td class="text-center">@(no++)</td>
                        <td>@item.Barang?.NamaBarang</td>
                        <td>@item.Barang?.NamaBarang</td>
                        <td class="text-center">@item.Jumlah</td>
                        <td>
                            @{ var ser = item.BarangSerials?.Select(s => s.SerialNumber).Where(s => s != "-").ToList() ?? new List<string>(); }
                            @(ser.Any() ? string.Join(", ", ser) : "-")
                        </td>
                        <td>@item.Keterangan</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="surat-ttd" style="margin-top:40px;">
            <div>
                <p><strong>Diserahkan Oleh</strong></p>
                <br><br><br><br>
                <p>(@User.Identity?.Name)</p>
                <p style="font-size:12px; color:#666;">Admin Gudang</p>
            </div>
            <div>
                <p><strong>Mengetahui</strong></p>
                <br><br><br><br>
                <p>(........................................)</p>
                <p style="font-size:12px; color:#666;">Kepala Gudang</p>
            </div>
            <div>
                <p><strong>Diterima Oleh</strong></p>
                <br><br><br><br>
                <p>(........................................)</p>
                <p style="font-size:12px; color:#666;">Pihak Penerima</p>
            </div>
        </div>
    </div>
    groupIdx++;
}
