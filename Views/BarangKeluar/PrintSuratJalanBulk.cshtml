@model IEnumerable<MyGudang.Models.BarangKeluar>
@{ 
    ViewData["Title"] = "Surat Jalan Barang Keluar"; 
    Layout = "~/Views/Shared/_Layout.cshtml"; 
    var kop = (MyGudang.Models.KopSurat)ViewBag.Kop; 
    var groupedData = Model.OrderBy(x => x.TanggalKeluar).GroupBy(x => x.NoSuratJalan).ToList();
}

<style>
    @@media print {
        .page-break { page-break-after: always; }
        .page-break:last-child { page-break-after: auto; }
    }
</style>

<div class="no-print mb-3">
    <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Cetak</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

@foreach (var group in groupedData)
{
    <div class="surat-container page-break" style="margin-bottom: 30px;">
        <div class="surat-header" style="text-align:left; border-bottom:none !important;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
                <div>
                    <h3 style="margin:0; font-weight:bold; font-size:22px;">@kop.NamaPerusahaan</h3>
                    @if (!string.IsNullOrEmpty(kop.SubJudul)) { <p style="font-size:14px; color:#666; margin:2px 0 0 0;">@kop.SubJudul</p> }
                    @if (!string.IsNullOrEmpty(kop.Alamat)) { <p style="font-size:12px; margin:2px 0 0 0;">@kop.Alamat</p> }
                    @{
                        var contacts = new List<string>();
                        if (!string.IsNullOrEmpty(kop.Telepon)) contacts.Add("Telp: " + kop.Telepon);
                        if (!string.IsNullOrEmpty(kop.Email)) contacts.Add("Email: " + kop.Email);
                        if (!string.IsNullOrEmpty(kop.Website)) contacts.Add(kop.Website);
                    }
                    @if (contacts.Any()) { <p style="font-size:11px; color:#888; margin:2px 0 0 0;">@string.Join(" | ", contacts)</p> }
                </div>
                @if (kop.TampilkanLogo) { <img src="/images/logo-ppn.png" alt="Logo" style="height:112px;"> }
            </div>
        </div>
        
        <hr style="border-top:3px solid #333; margin:10px 0;" />
        <h2 style="text-align:center; margin-top:20px; font-weight:bold; margin-bottom:25px;">SURAT JALAN</h2>

        <table style="width:100%; margin-bottom:20px;">
            <tr><td width="150"><strong>No. Surat Jalan</strong></td><td>: @group.Key</td></tr>
            <tr><td><strong>Tanggal Keluaran</strong></td><td>: @group.First().TanggalKeluar.ToString("dd MMMM yyyy")</td></tr>
        </table>
        
        <p>Harap diterima dengan baik barang-barang di bawah ini:</p>

        <table class="table table-bordered" style="margin-top:10px;">
            <thead>
                <tr>
                    <th width="50">No</th>
                    <th>Nama Barang</th>
                    <th>Penerima / PIC</th>
                    <th width="80">Jumlah</th>
                    <th>S/N</th>
                    <th>Keterangan</th>
                </tr>
            </thead>
            <tbody>
                @{ int no = 1; }
                @foreach (var item in group)
                {
                    <tr>
                        <td>@(no++)</td>
                        <td>@item.Barang?.NamaBarang</td>
                        <td>
                            @item.Penerima <br>
                            <small class="text-muted">PIC: @(item.Pic ?? "-")</small>
                        </td>
                        <td>@item.Jumlah</td>
                        <td>
                            @{ var ser = item.BarangSerials?.Select(s => s.SerialNumber).Where(s => s != "-").ToList() ?? new List<string>(); }
                            @(ser.Any() ? string.Join(", ", ser) : "-")
                        </td>
                        <td>@item.Keterangan</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="surat-ttd" style="margin-top:40px;">
            <div>
                <p><strong>Pengirim</strong></p>
                <br><br><br><br>
                <p>(........................................)</p>
            </div>
            <div>
                <p><strong>Mengetahui</strong></p>
                <br><br><br><br>
                <p>(........................................)</p>
            </div>
            <div>
                <p><strong>Penerima</strong></p>
                <br><br><br><br>
                <p>(........................................)</p>
            </div>
        </div>
    </div>
}
