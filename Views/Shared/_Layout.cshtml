                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a href="@Url.Action("Index","Stok")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stok" ? "active" : "")">
                                    <i class="far fa-circle nav-icon"></i><p>Data Stok</p>
