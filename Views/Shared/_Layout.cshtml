                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index","Peremajaan")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Peremajaan" ? "active" : "")">
                            <i class="nav-icon fas fa-sync-alt" style="color:#6f42c1;"></i>
