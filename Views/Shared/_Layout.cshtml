                    <li class="nav-item">
                        <a href="@Url.Action("Index","Laporan")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Laporan" ? "active" : "")">
                            <i class="nav-icon fas fa-chart-pie" style="color:#6f42c1;"></i>
