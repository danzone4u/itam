                    <li class="nav-item">
                        <a href="@Url.Action("Index","Kategori")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Kategori" ? "active" : "")">
                            <i class="nav-icon fas fa-tags"></i>
                            <p>Kategori</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index","Supplier")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Supplier" ? "active" : "")">
                            <i class="nav-icon fas fa-truck"></i>
                            <p>Supplier</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index","Arsip")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Arsip" ? "active" : "")">
                            <i class="nav-icon fas fa-archive"></i>
