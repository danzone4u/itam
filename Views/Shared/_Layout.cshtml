                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="@Url.Action("Index","User")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                                    <i class="far fa-circle nav-icon"></i><p>Manajemen User</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="@Url.Action("Index","KopSurat")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "KopSurat" ? "active" : "")">
                                    <i class="far fa-circle nav-icon"></i><p>Kop Surat</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="@Url.Action("Index","SuratSetting")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuratSetting" ? "active" : "")">
                                    <i class="far fa-circle nav-icon"></i><p>Nomor Surat</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="@Url.Action("Index","Backup")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Backup" ? "active" : "")">
                                    <i class="far fa-circle nav-icon"></i><p>Backup & Restore</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="@Url.Action("Index","ActivityLog")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ActivityLog" ? "active" : "")">
