                        var settingControllers = new[] { "ChartSetting", "User", "KopSurat", "SuratSetting", "Backup", "ActivityLog" };
                        var isSettingActive = settingControllers.Contains(ViewContext.RouteData.Values["controller"]?.ToString());
                    <li class="nav-item has-treeview @(isSettingActive ? "menu-open" : "")">
