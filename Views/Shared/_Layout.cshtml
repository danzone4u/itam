    <!-- Content Wrapper -->
    <div class="content-wrapper">
        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <h1 class="m-0">@ViewData["Title"]</h1>
                    </div>
                </div>
            </div>
        </div>

        <section class="content">
            <div class="container-fluid">
                @if (TempData["Success"] != null || TempData["Error"] != null)
                {
                    <script>
                    $(function(){
                        @if (TempData["Success"] != null)
                        {
                            <text>
                            Swal.fire({
                                icon: 'success',
                                title: 'Berhasil!',
                                html: '<p style="font-size:15px;color:#555">@Html.Raw(TempData["Success"]?.ToString()?.Replace("'", "\\'"))</p>',
                                showConfirmButton: false,
                                timer: 2500,
                                timerProgressBar: true,
                                background: '#fff',
                                iconColor: '#28a745',
                                customClass: {
                                    popup: 'animate__animated animate__fadeInDown',
                                    title: 'text-dark'
                                }
                            });
                            </text>
                        }
                        @if (TempData["Error"] != null)
                        {
                            <text>
                            Swal.fire({
                                icon: 'error',
                                title: 'Oops!',
                                html: '<p style="font-size:15px;color:#555">@Html.Raw(TempData["Error"]?.ToString()?.Replace("'", "\\'"))</p>',
                                confirmButtonColor: '#e74c3c',
                                confirmButtonText: '<i class="fas fa-check"></i> OK',
                                background: '#fff',
                                customClass: {
                                    popup: 'animate__animated animate__shakeX',
                                    title: 'text-danger'
                                }
                            });
                            </text>
                        }
                    });
                    </script>
                }
                @RenderBody()
            </div>
        </section>
    </div>

    <footer class="main-footer">
        <strong>&copy; @DateTime.Now.Year <a href="#">IT Region Jatimbalinus</a>.</strong> All rights reserved.
        <div class="float-right d-none d-sm-inline-block">
            <b>Version</b> 1.0
        </div>
    </footer>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.6.2/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/3.2.0/js/adminlte.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<script>
    $(document).ready(function () {
        $('.data-table').each(function() {
            var $table = $(this);
            // Add filter row in thead
            var $headerRow = $table.find('thead tr').first();
            var $filterRow = $('<tr class="dt-filter-row"></tr>');
            $headerRow.find('th').each(function() {
                $filterRow.append('<th></th>');
            });
            $table.find('thead').append($filterRow);

            var dt = $table.DataTable({
                "language": {
                    "search": "Cari:",
                    "lengthMenu": "Tampilkan _MENU_ data",
                    "info": "Menampilkan _START_ sampai _END_ dari _TOTAL_ data",
                    "paginate": { "first": "Pertama", "last": "Terakhir", "next": "Berikutnya", "previous": "Sebelumnya" },
                    "emptyTable": "Tidak ada data",
                    "zeroRecords": "Data tidak ditemukan"
                },
                "responsive": true,
                "autoWidth": false,
                "orderCellsTop": true,
                "initComplete": function() {
                    var api = this.api();
                    api.columns().every(function(idx) {
                        var column = this;
                        var $th = $($table.find('thead tr.dt-filter-row th').eq(idx));
                        var header = $headerRow.find('th').eq(idx).text().trim();

                        // Skip columns: No, Aksi, checkboxes, or columns with few unique values that are just numbers
                        if (!header || header === 'No' || header === 'Aksi' || header === '#' || header.length < 2) {
                            $th.html('');
                            return;
                        }

                        var uniqueVals = [];
                        column.data().each(function(val) {
                            var text = $('<div>').html(val).text().trim();
                            if (text && text !== '-' && uniqueVals.indexOf(text) === -1) uniqueVals.push(text);
                        });

                        // Only add dropdown if there are 2-50 unique values (useful for filtering)
                        if (uniqueVals.length >= 2 && uniqueVals.length <= 50) {
                            uniqueVals.sort();
                            var select = $('<select class="form-control form-control-sm dt-column-filter"><option value="">Semua</option></select>');
                            uniqueVals.forEach(function(val) {
                                select.append('<option value="' + val + '">' + val + '</option>');
                            });
                            $th.html(select);
                            select.on('change', function() {
                                var val = $(this).val();
                                column.search(val ? '^' + $.fn.dataTable.util.escapeRegex(val) + '$' : '', true, false).draw();
                            });
                        } else {
                            $th.html('');
                        }
                    });
                }
            });
        });
        $('.select2').select2({ theme: 'bootstrap4', placeholder: '-- Pilih --', allowClear: true });
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    $(function(){ $('.select2').select2({ theme: 'bootstrap4', placeholder: '-- Pilih --', allowClear: true }); });

    // Dark Mode Toggle
    (function() {
        var body = document.body;
        var toggle = document.getElementById('darkModeToggle');
        if (localStorage.getItem('darkMode') === 'true') {
            body.classList.add('dark-mode');
            if(toggle) toggle.querySelector('i').className = 'fas fa-sun';
        }
        if (toggle) {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                body.classList.toggle('dark-mode');
                var isDark = body.classList.contains('dark-mode');
                localStorage.setItem('darkMode', isDark);
                this.querySelector('i').className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            });
        }
    })();
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function () {
        // Strip all onsubmit confirm() attributes and replace with SweetAlert2
        $('form[onsubmit*="confirm"]').each(function () {
            var $form = $(this);
            var onsubmitAttr = $form.attr('onsubmit');
            var match = onsubmitAttr ? onsubmitAttr.match(/confirm\(['"](.*?)['"]\)/) : null;
            var message = match ? match[1] : 'Apakah Anda yakin ingin menghapus data ini?';
            // Remove native onsubmit so confirm() never fires
            $form.removeAttr('onsubmit');
            $form.data('delete-msg', message);
        });

        // Intercept delete form submissions with SweetAlert2
        $(document).on('submit', 'form[data-swal-delete]', function (e) {
            e.preventDefault();
        });
        $(document).on('click', 'form .btn-danger', function (e) {
            var $form = $(this).closest('form');
            if (!$form.data('delete-msg')) return; // not a delete form
            e.preventDefault();
            var form = $form[0];
            var message = $form.data('delete-msg');
            Swal.fire({
                title: '<i class="fas fa-exclamation-triangle" style="color:#e74c3c;"></i>',
                html: '<h5 style="margin-bottom:5px;">Konfirmasi Hapus</h5><p style="color:#666; font-size:14px;">' + message + '</p>',
                showCancelButton: true,
                confirmButtonColor: '#e74c3c',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-trash"></i> Ya, Hapus!',
                cancelButtonText: '<i class="fas fa-times"></i> Batal',
                customClass: {
                    popup: 'swal-delete-popup',
                    confirmButton: 'swal-confirm-btn',
                    cancelButton: 'swal-cancel-btn'
                },
                backdrop: 'rgba(0,0,0,0.5)',
                focusCancel: true
            }).then(function (result) {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });
</script>
<script>
    // Bulk Delete
    $(function(){
        $('#checkAll').on('change', function(){ $('.bulk-check').prop('checked', this.checked).trigger('change'); });
        $(document).on('change', '.bulk-check', function(){
            var cnt = $('.bulk-check:checked').length;
            $('#bulkCount').text(cnt);
            if(cnt > 0) $('#btnBulkDelete').removeClass('d-none'); else $('#btnBulkDelete').addClass('d-none');
            var all = $('.bulk-check').length;
            $('#checkAll').prop('checked', cnt === all && all > 0);
        });
        $('#btnBulkDelete').on('click', function(){
            var ids = []; $('.bulk-check:checked').each(function(){ ids.push($(this).val()); });
            if(ids.length === 0) return;
            var url = $(this).data('url');
            Swal.fire({
                icon: 'warning',
                html: '<h5>Hapus '+ids.length+' data?</h5><p style="color:#666">Data yang dihapus tidak dapat dikembalikan.</p>',
                showCancelButton: true,
                confirmButtonColor: '#e74c3c',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-trash"></i> Ya, Hapus!',
                cancelButtonText: '<i class="fas fa-times"></i> Batal',
                focusCancel: true
            }).then(function(result){
                if(result.isConfirmed){
                    var form = $('<form method="post" action="'+url+'"></form>');
                    form.append('@Html.AntiForgeryToken()');
                    ids.forEach(function(id){ form.append('<input type="hidden" name="ids" value="'+id+'">'); });
                    $('body').append(form);
                    form.submit();
                }
            });
        });

        // Global: upgrade all confirm('Yakin hapus?') to SweetAlert2
        $(document).on('click', 'form[onsubmit] button[class*="btn-danger"], form[onsubmit] button.btn-danger', function(e){
            var form = $(this).closest('form');
            if(form.attr('onsubmit') && form.attr('onsubmit').indexOf('confirm') >= 0){
                e.preventDefault();
                form.removeAttr('onsubmit');
                Swal.fire({
                    icon: 'warning',
                    title: '<span style="color:#e74c3c">Hapus Data?</span>',
                    html: '<p style="font-size:14px;color:#666">Data yang dihapus tidak dapat dikembalikan!</p>',
                    showCancelButton: true,
                    confirmButtonColor: '#e74c3c',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash"></i> Ya, Hapus!',
                    cancelButtonText: '<i class="fas fa-times"></i> Batal',
                    focusCancel: true,
                    customClass: { popup: 'animate__animated animate__fadeInDown' }
                }).then(function(result){
                    if(result.isConfirmed) form.submit();
                    else form.attr('onsubmit', "return confirm('Yakin hapus?')");
                });
            }
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
