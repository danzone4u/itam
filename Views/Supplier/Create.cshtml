@model itam.Models.Supplier
@{ ViewData["Title"] = "Tambah Supplier"; }
<div class="card card-outline card-primary">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-plus"></i> Tambah Supplier</h3></div>
    <form asp-action="Create" method="post">@Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row">
                <div class="col-md-6"><div class="form-group"><label asp-for="NamaSupplier"></label><input asp-for="NamaSupplier" class="form-control" /><span asp-validation-for="NamaSupplier" class="text-danger"></span></div></div>
                <div class="col-md-6"><div class="form-group"><label asp-for="Telepon"></label><input asp-for="Telepon" class="form-control" /></div></div>
            </div>
            <div class="form-group"><label asp-for="Email"></label><input asp-for="Email" class="form-control" type="email" /></div>
            <div class="form-group"><label asp-for="Alamat"></label><textarea asp-for="Alamat" class="form-control" rows="3"></textarea></div>
        </div>
        <div class="card-footer"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button> <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a></div>
    </form>
</div>
