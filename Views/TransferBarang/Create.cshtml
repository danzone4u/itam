@model MyGudang.Models.TransferBarang
@{ ViewData["Title"] = "Transfer Barang"; }
<div class="card card-outline card-warning">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-exchange-alt"></i> Transfer Barang Antar Ruangan</h3></div>
    <form asp-action="Create" method="post">@Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Pilih Barang</label>
                        <input type="text" id="searchBarang" class="form-control" list="listBarang" placeholder="Ketik nama barang..." autocomplete="off" />
                        <datalist id="listBarang">
                            @if (ViewBag.Barangs != null)
                            {
                                foreach (var b in (IEnumerable<MyGudang.Models.Barang>)ViewBag.Barangs)
                                {
                                    <option value="@b.NamaBarang" data-id="@b.Id"></option>
                                }
                            }
                        </datalist>
                        <input type="hidden" name="BarangId" id="selectedBarangId" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="Jumlah"></label>
                        <input asp-for="Jumlah" id="jumlahInput" class="form-control" min="1" value="1" readonly />
                        <small class="text-muted">Terhitung dari SN yang dipilih</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="TanggalTransfer"></label>
                        <input asp-for="TanggalTransfer" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Dari Ruangan</label>
                        <select name="DariLokasiId" asp-items="@ViewBag.Lokasis" class="form-control" required id="dariLokasi">
                            <option value="">-- Pilih Asal --</option>
                        </select>
                        <small class="text-muted" id="stokInfo"></small>
                    </div>
                </div>
                <div class="col-md-1 text-center" style="padding-top:35px;"><i class="fas fa-arrow-right fa-2x text-warning"></i></div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Ke Ruangan</label>
                        <select name="KeLokasiId" asp-items="@ViewBag.Lokasis" class="form-control" required>
                            <option value="">-- Pilih Tujuan --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="Keterangan"></label>
                        <input asp-for="Keterangan" class="form-control" placeholder="Opsional" />
                    </div>
                </div>
            </div>
        </div>
        
        <!-- SN SELECTION SECTION -->
        <div class="card-body border-top" id="snContainer" style="display:none; background-color: #fdfdfd;">
            <h5><i class="fas fa-barcode"></i> Pilih Serial Number untuk Transfer</h5>
            <div class="card card-outline card-info">
                <div class="card-header py-2">
                    <h3 class="card-title"><i class="fas fa-list"></i> Serial Number Tersedia <small class="text-muted">(Pilih SN yang akan dipindahkan)</small></h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-xs btn-info" id="btnCheckAll"><i class="fas fa-check-double"></i> Pilih Semua</button>
                        <button type="button" class="btn btn-xs btn-secondary" id="btnUncheckAll"><i class="fas fa-times"></i> Batal Semua</button>
                    </div>
                </div>
                <div class="card-body" id="snList" style="max-height:300px; overflow-y:auto;">
                    <!-- SN checkboxes loaded via AJAX -->
                </div>
                <div class="card-footer py-2">
                    <span>Terpilih: <strong id="selectedCount">0</strong> unit</span>
                </div>
            </div>
            <div id="selectedSnHiddenInputs"></div>
        </div>
        <!-- END SN SELECTION SECTION -->

        <div class="card-footer">
            <button type="submit" class="btn btn-warning"><i class="fas fa-exchange-alt"></i> Transfer</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Kembali</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
$(function(){
    // Auto-set BarangId from datalist search
    $('#searchBarang').on('input', function(){
        var typed = $(this).val();
        var matched = null;
        $('#listBarang option').each(function(){
            if ($(this).val() === typed) { matched = $(this); return false; }
        });
        if (matched) {
            $('#selectedBarangId').val(matched.data('id'));
            checkStok();
            loadSNs(matched.data('id'));
        } else {
            $('#snContainer').hide();
            $('#selectedSnHiddenInputs').empty();
            $('#jumlahInput').val(0);
        }
    });

    $('#dariLokasi').on('change', function(){ checkStok(); });

    function checkStok(){
        var barangId = $('#selectedBarangId').val();
        var lokasiId = $('#dariLokasi').val();
        if (barangId && lokasiId) {
            $.getJSON('@Url.Action("GetStokLokasi")?barangId=' + barangId + '&lokasiId=' + lokasiId, function(data){
                $('#stokInfo').html('Stok di ruangan ini: <strong>' + data.stok + '</strong>');
            });
        } else {
            $('#stokInfo').html('');
        }
    }

    function loadSNs(barangId) {
        if (!barangId) { $('#snContainer').hide(); return; }
        $.getJSON('@Url.Action("GetAvailableSerials","TransferBarang")' + '?barangId=' + barangId, function(data){
            var html = '';
            if (data.length === 0) {
                html = '<p class="text-muted">Tidak ada serial number tersedia untuk barang ini.</p>';
            } else {
                var unitNo = 0;
                data.forEach(function(sn){
                    var label = sn.serialNumber === '-' ? 'Unit ' + (++unitNo) : sn.serialNumber;
                    html += '<div class="custom-control custom-checkbox d-inline-block mr-3 mb-2">'
                        + '<input type="checkbox" name="rawSnCheck" class="custom-control-input sn-check" id="sn_'+sn.id+'" value="'+sn.id+'">'
                        + '<label class="custom-control-label" for="sn_'+sn.id+'">'+label+'</label></div>';
                });
            }
            $('#snList').html(html);
            $('#snContainer').show();
            updateCount();
        });
    }

    // Check/Uncheck all
    $('#btnCheckAll').click(function(){ $('.sn-check').prop('checked', true); updateCount(); });
    $('#btnUncheckAll').click(function(){ $('.sn-check').prop('checked', false); updateCount(); });
    $(document).on('change', '.sn-check', function(){ updateCount(); });

    function updateCount(){ 
        var c = $('.sn-check:checked').length;
        $('#selectedCount').text(c); 
        $('#jumlahInput').val(c > 0 ? c : 1); // fallback to 1 if user doesn't use SN correctly but backend checks it

        // Update hidden inputs for final submission
        var hiddenHtml = '';
        $('.sn-check:checked').each(function(){
            hiddenHtml += '<input type="hidden" name="serialIds[]" value="'+$(this).val()+'" />';
        });
        $('#selectedSnHiddenInputs').html(hiddenHtml);
    }
});
</script>
}
